---
import Layout from '../layouts/Layout.astro';

const milestones = [
  {
    amount: 500,
    label: 'Bottom shelf',
    desc: 'Cheap ingredients to take us through most of the week. Premium cocktails will be cut.',
  },
  {
    amount: 750,
    label: 'Middle shelf',
    desc: "The comfy zone. Should get us through the week without any cuts.",
  },
  {
    amount: 1000,
    label: 'Top shelf',
    desc: 'Premium ingredients, plus some off-menu specials and/or a punch-bowl night!',
  },
];

const suggested = [
  { amount: 12, drinks: 'covers about 4 drinks', alt: 'one bottle of Crude Tropi-500 bitters.' },
  { amount: 28, drinks: 'covers about 9 drinks', alt: "one bottle of Pusser's Rum.", featured: true },
  { amount: 48, drinks: 'covers about 16 drinks', alt: 'a handle of Olmeca Altos Plata Tequila.', featured: true },
  { amount: 60, drinks: 'covers about 20 drinks', alt: 'a bottle of Amaro Nonino Quintessentia.' },
  { amount: 100, drinks: 'covers about 33 drinks', alt: 'a set of Jamaican rums: Coruba, Smith & Cross, and Appleton 12 year Rare Casks.' },
  { amount: 150, drinks: 'covers about 50 drinks', alt: 'ALL of the non-alcoholic ingredients.' },
];

const tikiDrinks = [
  'Mai Tai',
  'Grungle Bird',
  'Painkiller',
  'Ancient Mariner',
  'Pampanito',
  "Lauwiliwilinukunuku\u02BBoi\u02BBoi",
  "Humuhumunukunukuapua\u02BBa",
];

const crowdFavorites = ['Espresso Martini', 'Margarita', 'Daiquiri'];

const classics = ['Paloma', 'Ranch Water', 'Tom Collins', 'Old Fashioned', 'Martini', 'Negroni'];
---

<Layout>
  <main class="container">
    <header>
      <h1>Mike's Beach Bar</h1>
      <p>
        Last year's inaugural run of Mike's Beach Bar was a resounding success.
        <br />
        Mike is ready to mix things up again, and needs your help to stock the bar!
      </p>
    </header>

    <section>
      <h2>The Menu</h2>

      <div class="menu-cards">
        <article class="menu-card">
          <h3>Favorites</h3>
          <ul>{crowdFavorites.map((d) => <li>{d}</li>)}</ul>
        </article>
        <article class="menu-card">
          <h3>Tiki</h3>
          <ul>{tikiDrinks.map((d) => <li>{d}</li>)}</ul>
        </article>
        <article class="menu-card">
          <h3>Classics</h3>
          <ul>{classics.map((d) => <li>{d}</li>)}</ul>
        </article>
      </div>

      <p class="muted">(and more!)</p>
    </section>

    <section>
      <h2>The Goal</h2>
      <p>
        Mike's accountant, Matt, has done
        <a
          href="https://docs.google.com/spreadsheets/d/1NgRxtqVga8s14sL5x3Kvozcg2tsxMTsXjyrhqqeBDgc/edit?usp=sharing"
          target="_blank"
          rel="noopener"
        >the math</a>
        <br />
        Here's how your contributions have helped so far
      </p>

      <div id="meter" class="meter card" data-milestones={JSON.stringify(milestones)}>
        <div class="meter-bar">
          <div class="meter-fill" style="width:0%"></div>
          {milestones.map((m) => (
            <div class="meter-marker" data-amount={m.amount}>
              <span>${m.amount}</span>
            </div>
          ))}
        </div>
        <p class="meter-status muted">Loading current pledges…</p>
      </div>

      <ul class="milestones">
        {[...milestones].reverse().map((m) => (
          <li>
            <strong>${m.amount} — {m.label}</strong>
            <br />
            {m.desc}
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Suggested donations</h2>
      <p class="muted">Click an amount to fill in the pledge form below</p>
      <div class="donations">
        {suggested.map((s) => (
          <button
            type="button"
            class={`donation ${s.featured ? 'featured' : ''}`}
            data-amount={s.amount}
          >
            <div class="donation-amount">${s.amount}</div>
            <div class="donation-desc">
              {s.drinks}<br />
              -- or --<br />
              {s.alt}
            </div>
          </button>
        ))}
      </div>
    </section>

    <section id="pledge-section">
      <h2>Contribute</h2>
      <p class="muted">
        Pay what you can - Mike's bar will exist no matter what, but with your help it'll be even more awesome
      </p>

      <div id="my-pledge-banner" class="card banner" hidden>
        <p>
          You pledged <strong id="my-pledge-amount"></strong> as
          <strong id="my-pledge-name"></strong>.
        </p>
        <div class="banner-actions">
          <button type="button" id="my-pledge-edit">Edit</button>
          <button type="button" id="my-pledge-delete" class="ghost">Delete</button>
        </div>
      </div>

      <form id="pledge-form" class="card">
        <div class="field">
          <label for="amount">Enter any amount (USD)</label>
          <input type="number" id="amount" name="amount" min="1" max="10000" step="1" required />
        </div>
        <div class="field">
          <label for="name">Your name</label>
          <input type="text" id="name" name="name" maxlength="50" required />
        </div>
        <div class="field">
          <label for="venmo">Venmo handle</label>
          <input type="text" id="venmo" name="venmo" maxlength="50" placeholder="@yourhandle" required />
          <p class="muted">Only Mike sees this. He'll Venmo you after total contributions hit at least $500.</p>
        </div>
        <div class="field checkbox">
          <label>
            <input type="checkbox" id="is_private" name="is_private" checked />
            Keep my name private (show as "Anonymous" on the public list)
          </label>
        </div>
        <button type="submit">Pledge</button>
        <p id="pledge-status" class="muted" aria-live="polite"></p>
      </form>
    </section>

    <section>
      <h2>Pledges</h2>
      <div class="pledge-wrap">
        <article class="pledge-card">
          <table id="pledge-list" class="pledges">
            <tbody>
              <tr class="empty"><td colspan="2" class="muted">Loading…</td></tr>
            </tbody>
          </table>
        </article>
      </div>
    </section>
  </main>

  <script>
    type Milestone = { amount: number; label: string; desc: string };
    type PublicPledge = { id: number; name: string | null; amount_cents: number; is_private: 0 | 1 };
    type MyPledge = { id: number; name: string; amount_cents: number; venmo_handle: string; is_private: 0 | 1 };

    const fmt = (cents: number) =>
      `$${(cents / 100).toFixed(cents % 100 === 0 ? 0 : 2)}`;

    const escapeHtml = (s: string) =>
      s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!),
      );

    const meterEl = document.getElementById('meter')!;
    const milestones: Milestone[] = JSON.parse(meterEl.dataset.milestones!);
    const goalCents = milestones[milestones.length - 1].amount * 100;
    const headlineCents = milestones[1].amount * 100;

    // Position markers on the bar
    meterEl.querySelectorAll<HTMLElement>('.meter-marker').forEach((m) => {
      const amt = Number(m.dataset.amount) * 100;
      m.style.left = `${(amt / goalCents) * 100}%`;
    });

    async function loadPledges() {
      const res = await fetch('/api/pledges');
      if (!res.ok) return;
      const { pledges, total_cents } = (await res.json()) as {
        pledges: PublicPledge[];
        total_cents: number;
      };

      const fill = meterEl.querySelector('.meter-fill') as HTMLElement;
      const pct = Math.min(100, (total_cents / goalCents) * 100);
      fill.style.width = pct + '%';

      meterEl.querySelectorAll('.meter-marker').forEach((el) => {
        const amt = Number((el as HTMLElement).dataset.amount) * 100;
        el.classList.toggle('hit', total_cents >= amt);
      });

      const status = meterEl.querySelector('.meter-status')!;
      if (total_cents >= goalCents) {
        status.textContent = `${fmt(total_cents)} pledged — top shelf unlocked! 🎉`;
      } else if (total_cents >= headlineCents) {
        status.textContent = `${fmt(total_cents)} pledged — middle shelf locked in. ${fmt(goalCents - total_cents)} to top shelf.`;
      } else {
        status.textContent = `${fmt(total_cents)} pledged — ${fmt(headlineCents - total_cents)} to middle shelf.`;
      }

      const tbody = document.querySelector('#pledge-list tbody')!;
      tbody.innerHTML = '';
      if (pledges.length === 0) {
        tbody.innerHTML = '<tr class="empty"><td colspan="2" class="muted">No pledges yet — be the first!</td></tr>';
      } else {
        for (const p of pledges) {
          const tr = document.createElement('tr');
          const name = p.is_private ? 'Anonymous' : p.name ?? 'Anonymous';
          tr.innerHTML = `<td class="pl-amt">${fmt(p.amount_cents)}</td><td class="pl-name">${escapeHtml(name)}</td>`;
          tbody.appendChild(tr);
        }
      }
    }

    // Suggested donation quick-picks
    document.querySelectorAll<HTMLButtonElement>('.donation').forEach((b) => {
      b.addEventListener('click', () => {
        (document.getElementById('amount') as HTMLInputElement).value = b.dataset.amount!;
        document.getElementById('pledge-section')!.scrollIntoView({ behavior: 'smooth' });
        (document.getElementById('name') as HTMLInputElement).focus();
      });
    });

    // Form submit (create or edit)
    const form = document.getElementById('pledge-form') as HTMLFormElement;
    const status = document.getElementById('pledge-status')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submit = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      submit.disabled = true;
      status.textContent = 'Submitting…';

      try {
        const fd = new FormData(form);

        const body = {
          name: String(fd.get('name')).trim(),
          amount: Number(fd.get('amount')),
          venmo_handle: String(fd.get('venmo')).trim(),
          is_private: fd.get('is_private') === 'on',
        };

        const editing = form.dataset.editingId;
        const url = editing ? `/api/pledges/${editing}` : '/api/pledges';
        const method = editing ? 'PATCH' : 'POST';

        const res = await fetch(url, {
          method,
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(body),
        });

        if (res.ok) {
          status.textContent = editing ? 'Pledge updated. Thanks!' : 'Thanks for pledging!';
          form.reset();
          delete form.dataset.editingId;
          (document.getElementById('is_private') as HTMLInputElement).checked = true;
          await Promise.all([loadPledges(), loadMyPledge()]);
        } else {
          const { error } = await res
            .json()
            .catch(() => ({ error: 'Something went wrong' }));
          status.textContent = `Error: ${error}`;
        }
      } catch {
        status.textContent = 'Error: Something went wrong. Please try again.';
      } finally {
        submit.disabled = false;
      }
    });

    async function loadMyPledge() {
      const banner = document.getElementById('my-pledge-banner')!;
      const res = await fetch('/api/pledges/me');
      if (!res.ok) {
        banner.hidden = true;
        return;
      }
      const p = (await res.json()) as MyPledge;
      banner.hidden = false;
      document.getElementById('my-pledge-amount')!.textContent = fmt(p.amount_cents);
      document.getElementById('my-pledge-name')!.textContent =
        p.is_private ? `${p.name} (private)` : p.name;

      document.getElementById('my-pledge-edit')!.onclick = () => {
        (document.getElementById('amount') as HTMLInputElement).value = String(p.amount_cents / 100);
        (document.getElementById('name') as HTMLInputElement).value = p.name;
        (document.getElementById('venmo') as HTMLInputElement).value = p.venmo_handle;
        (document.getElementById('is_private') as HTMLInputElement).checked = p.is_private === 1;
        form.dataset.editingId = String(p.id);
        document.getElementById('pledge-section')!.scrollIntoView({ behavior: 'smooth' });
      };

      document.getElementById('my-pledge-delete')!.onclick = async () => {
        if (!confirm('Delete your pledge?')) return;
        const r = await fetch(`/api/pledges/${p.id}`, { method: 'DELETE' });
        if (r.ok) {
          banner.hidden = true;
          form.reset();
          delete form.dataset.editingId;
          (document.getElementById('is_private') as HTMLInputElement).checked = true;
          status.textContent = 'Pledge deleted.';
          await loadPledges();
        }
      };
    }

    loadPledges();
    loadMyPledge();
  </script>

  <style>
    .menu-cards {
      display: grid;
      grid-template-columns: 1fr 1.5fr 1fr;
      gap: 0.75rem;
      margin: 1rem 0 0.5rem;
    }
    .menu-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 1rem 0.75rem;
    }
    .menu-card h3 {
      margin: 0 0 0.75rem;
      letter-spacing: 0.05em;
      font-size: 1.4rem;
      color: var(--ink-soft);
      font-family: "Limelight", Georgia, serif;
      font-weight: 400;
    }
    .menu-card ul {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 1rem;
      line-height: 1.6;
      color: var(--ink);
      overflow-wrap: anywhere;
    }
    @media (max-width: 600px) {
      .menu-cards { grid-template-columns: 1fr; }
    }

    .meter { margin: 1rem 0 2.5rem; }
    .meter-bar {
      position: relative;
      height: 18px;
      background: var(--sand-dark);
      border-radius: 9px;
    }
    .meter-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--sun), var(--sunset));
      border-radius: 9px;
      transition: width 0.6s ease;
    }
    .meter-marker {
      position: absolute;
      top: -4px;
      transform: translateX(-50%);
      pointer-events: none;
    }
    .meter-marker::before {
      content: '';
      display: block;
      width: 2px;
      height: 26px;
      background: var(--ocean-dark);
      margin: 0 auto;
    }
    .meter-marker span {
      position: absolute;
      top: 28px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 0.75rem;
      color: var(--ink-soft);
      white-space: nowrap;
    }
    .meter-marker.hit::before { background: var(--sunset); }
    .meter-status { margin: 2.5rem 0 0; }

    .milestones { list-style: none; padding: 0; }
    .milestones li {
      padding: 0.6rem 0;
      border-bottom: 1px dashed var(--line);
    }
    .milestones li:last-child { border-bottom: none; }

    .donations {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0.75rem;
    }
    .donation {
      text-align: center;
      background: var(--paper);
      border: 1px solid var(--line);
      color: var(--ink);
      padding: 1rem;
      border-radius: 10px;
      cursor: pointer;
      transition: transform 0.1s, background 0.1s;
      font-weight: normal;
    }
    .donation:hover {
      background: var(--sand);
      transform: translateY(-1px);
    }
    .donation-amount {
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--ink-soft);
      font-family: "Limelight", Georgia, serif;
    }
    .donation-desc {
      font-size: 0.85rem;
      color: var(--ink-soft);
      margin-top: 0.25rem;
    }
    .donation.featured {
      border-color: var(--sun);
      border-width: 2px;
    }

    .field.checkbox label {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 0.5rem;
      font-weight: 400;
    }
    .field.checkbox input { width: auto; }

    .pledge-wrap {
      display: grid;
      grid-template-columns: 1fr 1.5fr 1fr;
      gap: 0.75rem;
    }
    .pledge-card {
      grid-column: 2;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 1rem 0.75rem;
    }
    @media (max-width: 600px) {
      .pledge-wrap { grid-template-columns: 1fr; }
      .pledge-card { grid-column: 1; }
    }
    .pledges {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      margin: 0;
    }
    .pledges :global(td) {
      padding: 0.25rem 0;
      border: none;
      width: 50%;
    }
    .pledges :global(td.pl-amt) {
      text-align: right;
      padding-right: 0.6rem;
      font-weight: 700;
      color: var(--ocean-dark);
    }
    .pledges :global(td.pl-name) {
      text-align: left;
      padding-left: 0.6rem;
    }
    .pledges :global(tr.empty td) { text-align: center; padding: 0.5rem 0; width: auto; }

    .banner {
      background: #fff5dc;
      border-color: var(--sun);
      margin-bottom: 1rem;
    }
    .banner p { margin: 0 0 0.5rem; }
    .banner-actions {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
    }
    .banner button.ghost {
      background: transparent;
      color: var(--sunset);
      border: 1px solid var(--sunset);
    }
    .banner button.ghost:hover { background: var(--sand); color: var(--sunset); }
  </style>
</Layout>
